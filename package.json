    "next": "14.2.35",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.10.0",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
