# Givenest — environment variables template.
# Copy to `.env.local` for development and fill in secrets.

# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://givenest.com
ADMIN_EMAILS=dustin@givenest.com,kyndall@givenest.com

# ── Supabase (auth + Postgres) ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — required for `auth.admin.inviteUserByEmail` (used by
# /api/admin/landlords to send magic-link invites to new property owners).
# Server-only. NEVER expose to client bundles. Pull from the Supabase
# project's API settings → "service_role" secret.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── Spark / ARMLS replication ───────────────────────────────────────────────
SPARK_API_TOKEN=

# ── Maricopa County Assessor (tax history on /buy/<key> property pages) ────
# Used by lib/maricopa.ts → /parcel/{apn}/valuations to populate the
# "Tax History" tab on the sales-history table. Coverage: Maricopa County
# only (~70% of our listings — Phoenix metro, Scottsdale, Paradise Valley,
# Gilbert, Mesa, Chandler, Tempe). Pinal/Pima/Yavapai listings will gracefully
# show "no tax history available" until we add those counties or upgrade
# to a nationwide provider (ATTOM/Estated).
#
# Token request: fill out the contact form at
# https://preview.mcassessor.maricopa.gov/contact/ with subject
# "API Token/Question" — they email a token within a business day.
MARICOPA_API_TOKEN=

# ── Cron (all /api/cron/* routes) ───────────────────────────────────────────
CRON_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Anthropic (vision — classifies listing photos for social-post ordering) ─
# Used by the social-draft-listing cron to classify each MLS photo
# (kitchen, backyard, living, etc.) and reorder the carousel / reel clip
# sequence. Cached per image URL — only the first draft of a listing hits
# the API; re-runs are free.
ANTHROPIC_API_KEY=
# Optional — override the default classifier model (claude-haiku-4-5).
# ANTHROPIC_CLASSIFIER_MODEL=claude-haiku-4-5

# ── Stripe (charity subscriptions + landlord invoicing) ────────────────────
# Charity subs: app/api/stripe/webhook handles checkout.session.completed
# with metadata.charity_id. Landlord billing: same webhook handles setup-
# mode Checkout sessions (saved card via SetupIntent) + invoice events
# generated by /api/cron/monthly-invoices.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Landlord email notifications (Resend) ──────────────────────────────────
# Sender address for landlord-facing emails (welcome, invoice ready, receipts,
# payment-failed). Defaults to Resend's onboarding sender for local dev;
# point at a verified givenest.com sender in prod for deliverability.
# LANDLORD_EMAIL_FROM=Givenest <hello@givenest.com>
# Comma-separated admin recipients for ops alerts (e.g. payment-failed
# notifications). Defaults to the founders if unset.
# LANDLORD_ADMIN_NOTIFY=dustin@givenest.com,kyndall@givenest.com

# ── Vercel Blob (Story image uploads) ───────────────────────────────────────
# Required for /api/cron/social-draft-listing STORY render step.
BLOB_READ_WRITE_TOKEN=

# ── Instagram (Phase 3+) ────────────────────────────────────────────────────
# Provision from the Meta Developer app once it's created.
# IG_BUSINESS_ACCOUNT_ID=
# IG_APP_ID=
# IG_APP_SECRET=
# IG_ACCESS_TOKEN=
# INSTAGRAM_ENABLED=false
# INSTAGRAM_AUTO_POST=false

# ── Remotion (Phase 2+ — Reels rendering) ───────────────────────────────────
# REMOTION_AWS_ACCESS_KEY_ID=
# REMOTION_AWS_SECRET_ACCESS_KEY=
# REMOTION_AWS_REGION=us-west-2
# REMOTION_LAMBDA_FUNCTION_NAME=
# REMOTION_SERVE_URL=
